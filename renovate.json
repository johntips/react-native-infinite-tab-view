{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":prHourlyLimit2",
    "group:allNonMajor"
  ],
  "schedule": ["before 6am on monday"],
  "timezone": "Asia/Tokyo",
  "labels": ["dependencies"],
  "rangeStrategy": "bump",
  "packageRules": [
    {
      "description": "Maintenance mode: only security + devDeps patch updates",
      "matchDepTypes": ["dependencies", "peerDependencies"],
      "matchUpdateTypes": ["major", "minor"],
      "enabled": false
    },
    {
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true,
      "automergeType": "pr"
    }
  ],
  "prConcurrentLimit": 3,
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "automerge": true
  }
}
